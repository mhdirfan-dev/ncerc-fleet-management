{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "Dashboard.html"
    },
    {
      "src": "/entry_compressed.mp4",
      "dest": "/entry_compressed.mp4"
    },
    {
      "src": "/exit_compressed.mp4",
      "dest": "/exit_compressed.mp4"
    }
  ]
}